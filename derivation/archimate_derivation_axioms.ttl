@prefix archi: <https://purl.org/archimate/owl#> .
@prefix deriv: <https://purl.org/archimate/derivation#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# Relation abbreviations from the ArchiMate 3.2 spec 
# https://pubs.opengroup.org/architecture/archimate3-doc/ch-relationships-Normative.html#sec-Relationship-Tables
# (a)ccess (c)omposition (f)low a(g)gregation ass(i)gnment i(n)fluence ass(o)ciation (r)ealization (s)pecialization (t)riggering ser(v)ing

archi:access          archi:relAbbreviation "a"; archi:relNotation "(a)ccess".
archi:composition     archi:relAbbreviation "c"; archi:relNotation "(c)omposition".
archi:flow            archi:relAbbreviation "f"; archi:relNotation "(f)low".
archi:aggregation     archi:relAbbreviation "g"; archi:relNotation "a(g)gregation".
archi:assignment      archi:relAbbreviation "i"; archi:relNotation "ass(i)gnment".
archi:influence       archi:relAbbreviation "n"; archi:relNotation "i(n)fluence".
archi:association     archi:relAbbreviation "o"; archi:relNotation "ass(o)ciation".
archi:realization     archi:relAbbreviation "r"; archi:relNotation "(r)ealization".
archi:specialization  archi:relAbbreviation "s"; archi:relNotation "(s)pecialization".
archi:triggering      archi:relAbbreviation "t"; archi:relNotation "(t)riggering".
archi:serving         archi:relAbbreviation "v"; archi:relNotation "ser(v)ing".

# "Weaker" is useful to know but not sifficient, because of all exceptions in B.4. Restrictions on Applying Derivation Rules
archi:weakerThan      a owl:AnnotationProperty;
  rdfs:domain owl:ObjectProperty; rdfs:range owl:ObjectProperty; rdfs:label "weaker than"; rdfs:comment "Subject (relation) is weaker than object (relation)".
archi:weakerOrEqualTo a owl:AnnotationProperty, owl:TransitiveProperty, owl:ReflexiveProperty;
  rdfs:domain owl:ObjectProperty; rdfs:range owl:ObjectProperty; rdfs:label "weaker or equal to"; rdfs:comment "Subject (relation) is transitively weaker than object (relation) or equal to it".
archi:weakerThan rdfs:subPropertyOf archi:weakerOrEqualTo.

# B.2.2. Valid Derivations for Structural Relationships
archi:realization archi:weakerThan archi:assignment .
archi:assignment  archi:weakerThan archi:aggregation.
archi:aggregation archi:weakerThan archi:composition.
# B.3.3. Potential Derivation for Dependency Relationships
archi:association archi:weakerThan archi:influence  .
archi:influence   archi:weakerThan archi:access     .
archi:access      archi:weakerThan archi:serving    .
# Dynamic
#  archi:triggering
#  archi:flow
# Other
#  archi:specialization

# Derivation rules from relationships.xml, which is transcribed from the ArchiMate 3.2 spec.
# Each rule lists the relations allowed from a source element to a target element.
# Search for "" for 3 exceptions https://github.com/AlbertoDMendoza/archimate_ontology/issues/3

### ApplicationCollaboration
deriv:ApplicationCollaboration-cfgostv-ApplicationCollaboration
  a deriv:ArchimateRelationshipDerivation;
  deriv:source archi:ApplicationCollaboration;
  deriv:target archi:ApplicationCollaboration;
  deriv:relAbbreviation "cfgostv";
  deriv:relation archi:composition, archi:flow, archi:aggregation, archi:association, archi:specialization, archi:triggering, archi:serving.

