@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix archimate: <https://purl.org/archimate#> .
@prefix myModel: <https://example.org/myModel#> .
@base <https://example.org/myModel> .

### ArchiMate Specialization Profile Examples
<#> rdf:type owl:Ontology ;
    owl:imports <https://purl.org/archimate/owl> ;
    rdfs:label "ArchiMate Profile Examples" ;
    rdfs:comment "Example specialization profiles for ArchiMate elements. These demonstrate how to create custom subtypes of standard ArchiMate elements using the profile pattern. The myModel: prefix is illustrative — organizations define their own namespace. This file is not a published specification." ;
    dct:description "Profile classes are owl:Class that specialize standard ArchiMate elements via rdfs:subClassOf and archimate:specialization. SHACL shapes for these profiles are defined in validation/archimate_validation_profiles.ttl." ;
    dct:creator "Alberto D. Mendoza" ;
    dct:created "2026-02-10"^^xsd:date ;
    dct:modified "2026-05-09"^^xsd:date ;
    owl:versionInfo "Sample" .

# DESIGN NOTES
# ArchiMate profiles allow user-defined subtypes of standard elements,
# e.g. BusinessActor → Person, Organization. In native RDF, we model them as real OWL
# classes in the specialization hierarchy:
#
#   myModel:Person a owl:Class ;
#       rdfs:subClassOf archimate:BusinessActor ;
#       archimate:specialization archimate:BusinessActor .
#
# Why this works:
# - rdfs:subClassOf gives OWL inference (a myModel:Person is-a archimate:BusinessActor)
# - archimate:specialization (owl:TransitiveProperty) enables derivation rules (PDR1-4)
# - Profile classes can have SHACL shapes defined in validation/archimate_validation_profiles.ttl
# - The profile class IS the shape (implicit target pattern) — no separate shape needed
# - Profile shapes declare only what is new and specific to the profile;
#   archimate:name and archimate:documentation are enforced by Level 1 core validation
# - Profiles nest naturally: Employee → Person → BusinessActor
#
# The myModel: prefix is illustrative. Organizations deploying this ontology define
# their own namespace. The three-declaration pattern is the mechanism; the namespace is yours.
#
# These are example profiles (not part of the ArchiMate specification).
# Common specializations by element type:
#   BusinessActor    → Person, Organization, Department, Team, Committee
#   BusinessRole     → Manager, Analyst, Developer, Auditor
#   BusinessProcess  → CoreProcess, SupportProcess, ManagementProcess
#   BusinessObject   → Contract, Invoice, Policy, Report
#   ApplicationComponent → Microservice, Database, WebApplication, API
#   Node             → Server, VM, Container, CloudInstance
#   Artifact         → SourceCode, Configuration, LogFile, Schema


### 1. BusinessActor Profile Classes

myModel:Person rdf:type owl:Class ;
    rdfs:subClassOf archimate:BusinessActor ;
    archimate:specialization archimate:BusinessActor ;
    rdfs:label "Person" ;
    rdfs:comment "A BusinessActor representing an individual person." .

myModel:Organization rdf:type owl:Class ;
    rdfs:subClassOf archimate:BusinessActor ;
    archimate:specialization archimate:BusinessActor ;
    rdfs:label "Organization" ;
    rdfs:comment "A BusinessActor representing a group of people or organizational unit." .


### 2. Profile-Specific Properties

## Person Properties
myModel:firstName rdf:type owl:DatatypeProperty ;
    rdfs:label "first name" ;
    rdfs:comment "First name of a Person." ;
    rdfs:domain myModel:Person ;
    rdfs:range xsd:string .

myModel:lastName rdf:type owl:DatatypeProperty ;
    rdfs:label "last name" ;
    rdfs:comment "Last name of a Person." ;
    rdfs:domain myModel:Person ;
    rdfs:range xsd:string .

myModel:dateOfBirth rdf:type owl:DatatypeProperty ;
    rdfs:label "date of birth" ;
    rdfs:comment "Date of birth of a Person." ;
    rdfs:domain myModel:Person ;
    rdfs:range xsd:date .

myModel:email rdf:type owl:DatatypeProperty ;
    rdfs:label "email" ;
    rdfs:comment "Email address of a Person." ;
    rdfs:domain myModel:Person ;
    rdfs:range xsd:anyURI .


