@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix archimate: <https://purl.org/archimate#> .
@prefix myModel: <https://example.org/myModel#> .
@base <https://purl.org/archimate/validation/profiles> .

### SHACL Shapes for ArchiMate Specialization Profiles
<#> rdf:type owl:Ontology ;
    owl:imports <https://purl.org/archimate/owl> ;
    rdfs:label "ArchiMate Profile Shapes — Example" ;
    rdfs:comment "Example SHACL shapes for ArchiMate specialization profiles. Profile classes are owl:Class that specialize standard ArchiMate elements; this file defines their typed attributes. The myModel: prefix is illustrative — organizations define their own namespace. This file is not a published specification." ;
    dct:creator "Alberto D. Mendoza" ;
    dct:created "2026-02-15"^^xsd:date ;
    dct:modified "2026-05-28"^^xsd:date ;
    dct:license <http://www.apache.org/licenses/LICENSE-2.0> ;
    owl:versionInfo "Sample" ;
    sh:declare [
        sh:prefix "archimate" ;
        sh:namespace "https://purl.org/archimate#"^^xsd:anyURI ;
    ] , [
        sh:prefix "myModel" ;
        sh:namespace "https://example.org/myModel#"^^xsd:anyURI ;
    ] , [
        sh:prefix "rdf" ;
        sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI ;
    ] , [
        sh:prefix "rdfs" ;
        sh:namespace "http://www.w3.org/2000/01/rdf-schema#"^^xsd:anyURI ;
    ] .

### NOTES
# Profile classes (defined in ontology/archimate_profile_examples.ttl) are owl:Class
# that specialize standard ArchiMate elements via rdfs:subClassOf and
# archimate:specialization. This file defines their SHACL shapes — typed attributes
# that give profiles meaning.
#
# The myModel: prefix is illustrative. Organizations deploying this ontology define
# their own namespace. The three-declaration pattern (rdfs:subClassOf +
# archimate:specialization + sh:NodeShape) is the mechanism; the namespace is yours.
#
# The profile class IS the shape (implicit target pattern: class URI = shape URI).
# Applications discover profile shapes via sh:property, same as any other shape.
#
# archimate:name and archimate:documentation are enforced by Level 1 core validation
# (archimate_validation_core.ttl) and are not redeclared in profile shapes.
# Profile shapes declare only what is new and specific to the profile.
#
# This validation file should be used alongside:
# - archimate_validation_core.ttl (Level 1: graph integrity, concept requirements)
# - archimate_validation_metamodel.ttl (Level 2: abstract metamodel pattern rules)
# - archimate_validation_<layer>.ttl (Level 3: per-element-type relationship combinations)
# - ../derivation/archimate_derivation_rules.ttl (derivation rules)

### 1. BusinessActor Profile Shapes

## Person Shape
myModel:Person a sh:NodeShape ;
    rdfs:label "Person" ;
    rdfs:comment "Typed attribute shape for the Person profile (specialization of BusinessActor). Declares only profile-specific properties; archimate:name and archimate:documentation are enforced by Level 1 core validation." ;
    sh:property [
        sh:path myModel:firstName ;
        sh:name "First Name" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:order 1
    ] ;
    sh:property [
        sh:path myModel:lastName ;
        sh:name "Last Name" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:order 2
    ] ;
    sh:property [
        sh:path myModel:dateOfBirth ;
        sh:name "Date of Birth" ;
        sh:datatype xsd:date ;
        sh:order 3
    ] ;
    sh:property [
        sh:path myModel:email ;
        sh:name "Email" ;
        sh:datatype xsd:anyURI ;
        sh:order 4
    ] .

## Organization Shape
myModel:Organization a sh:NodeShape ;
    rdfs:label "Organization" ;
    rdfs:comment "Typed attribute shape for the Organization profile (specialization of BusinessActor). Declares only profile-specific properties; archimate:name and archimate:documentation are enforced by Level 1 core validation." ;
    sh:property [
        sh:path archimate:aggregation ;
        sh:name "Members" ;
        sh:class myModel:Person ;
        sh:order 1
    ] .
